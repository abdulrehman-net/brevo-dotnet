@Abdul.Brevo.Conversations.SampleApi_HostAddress = http://localhost:5152

POST {{Abdul.Brevo.Conversations.SampleApi_HostAddress}}/messages
Content-Type: application/json

{
  "visitorId": "visitor-1",
  "text": "Hello from Abdul API!",
  "agentEmail": "[EMAIL_ADDRESS]",
  "agentName": "Abdul Bot",
  "receivedFrom": "AbdulSupport"
}

